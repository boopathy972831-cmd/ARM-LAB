void UART0_CONFIG(void)
{
PINSEL0 |=0x5;
U0LCR=0X83;
U0DLL=97;
U0DLM=0;
U0LCR=0X03;
}
void UART0_INT_CONFIG(void)
{
VICIntSelect=0;
VICVectCntl0=(1<<5)|6;
VICVectAddr0=(unsigned long)UART0_ISR;
U0IER=(1<<1)|(1<<0);
VICIntEnable=1<<6;
}

 

